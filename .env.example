# Sanity CMS — leave unset to run on mock content (see src/lib/mock-data.ts)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Contact form email (Resend) — leave unset to just log submissions server-side
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Video hosting: individual projects carry their own muxPlaybackId in Sanity,
# so no global env var is needed for Mux itself — just a Mux account +
# the sanity-plugin-mux-input plugin configured in your Sanity Studio.
